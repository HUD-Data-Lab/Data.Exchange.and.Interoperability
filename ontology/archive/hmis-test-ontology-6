    <!-- http://hmis.hud.gov/ontology#HPDateOfEngagementRule -->

    <owl:NamedIndividual rdf:about="http://hmis.hud.gov/ontology#HPDateOfEngagementRule">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <rdfs:comment>Homelessness Prevention projects require DateOfEngagement</rdfs:comment>
        <shacl:sparql>
            <rdf:Description>
                <shacl:message>Homelessness Prevention enrollments (ProjectType 12) must have DateOfEngagement.</shacl:message>
                <shacl:select>
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:inProject ?project .
                ?project hmis:ProjectType 12 .
                
                FILTER NOT EXISTS {
                    $this hmis:DateOfEngagement ?date .
                }
            }
        </shacl:select>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:sparql>
        <shacl:targetClass rdf:resource="http://hmis.hud.gov/ontology#Enrollment"/>
    </owl:NamedIndividual>
    


    <!-- http://hmis.hud.gov/ontology#HouseholdHeadRule -->

    <owl:NamedIndividual rdf:about="http://hmis.hud.gov/ontology#HouseholdHeadRule">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <rdfs:comment>Each household must have exactly one Head of Household</rdfs:comment>
        <shacl:sparql>
            <rdf:Description>
                <shacl:message>Household {$this} must have exactly one member with RelationshipToHoH = 1 (Self).</shacl:message>
                <shacl:select>
            SELECT $this (COUNT(?hoh) as ?hohCount) WHERE {
                $this a hmis:Household ;
                      hmis:hasMember ?enrollment .
                ?enrollment hmis:RelationshipToHoH 1 .
            }
            GROUP BY $this
            HAVING (?hohCount != 1)
        </shacl:select>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:sparql>
        <shacl:targetClass rdf:resource="http://hmis.hud.gov/ontology#Household"/>
    </owl:NamedIndividual>
    


    <!-- http://hmis.hud.gov/ontology#LongTermNoExitRule -->

    <owl:NamedIndividual rdf:about="http://hmis.hud.gov/ontology#LongTermNoExitRule">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <rdfs:comment>Flag enrollments open &gt;1 year for review</rdfs:comment>
        <shacl:sparql>
            <rdf:Description>
                <shacl:message>Enrollment has been open for over 1 year without exit. Verify enrollment is still active.</shacl:message>
                <shacl:select>
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:EntryDate ?entry .
                FILTER NOT EXISTS { $this hmis:ExitDate ?exit }
                FILTER(?entry &lt; NOW() - &quot;P365D&quot;^^xsd:duration)
            }
        </shacl:select>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Info"/>
            </rdf:Description>
        </shacl:sparql>
        <shacl:targetClass rdf:resource="http://hmis.hud.gov/ontology#Enrollment"/>
    </owl:NamedIndividual>
    


    <!-- http://hmis.hud.gov/ontology#MissingSSNRule -->

    <owl:NamedIndividual rdf:about="http://hmis.hud.gov/ontology#MissingSSNRule">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <rdfs:comment>Track clients with missing SSN for data quality</rdfs:comment>
        <shacl:sparql>
            <rdf:Description>
                <shacl:message>Client is missing SSN. Consider collecting if possible.</shacl:message>
                <shacl:select>
            SELECT $this WHERE {
                $this a hmis:Client .
                FILTER NOT EXISTS { $this hmis:SSN ?ssn }
            }
        </shacl:select>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Info"/>
            </rdf:Description>
        </shacl:sparql>
