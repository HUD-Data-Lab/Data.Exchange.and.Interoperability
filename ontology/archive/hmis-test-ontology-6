    <!-- http://hmis.hud.gov/ontology#ProjectShape -->

    <owl:NamedIndividual rdf:about="http://hmis.hud.gov/ontology#ProjectShape">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <rdfs:comment>Validation rules for Project entity</rdfs:comment>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                <shacl:maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:maxCount>
                <shacl:message>ProjectID is required</shacl:message>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#ProjectID"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                <shacl:maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:maxCount>
                <shacl:message>ProjectName is required</shacl:message>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#ProjectName"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                <shacl:maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:maxCount>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#ProjectType"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
                <shacl:sparql>
                    <rdf:Description>
                        <shacl:message>ProjectType value {$value} is invalid. Must be from ProjectTypeScheme (0, 1, 2, 3, 4, 6, 7, 8, 9, 10, 11, 12, 13, 14).</shacl:message>
                        <shacl:select>
                SELECT $this ?value WHERE {
                    $this hmis:ProjectType ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:ProjectTypeScheme ;
                                 skos:notation ?value .
                    }
                }
            </shacl:select>
                    </rdf:Description>
                </shacl:sparql>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
                <shacl:maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:maxCount>
                <shacl:message>OperatingStartDate is required</shacl:message>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#OperatingStartDate"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                <shacl:message>ProjectCoC must be in format XX-NNN</shacl:message>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#ProjectCoC"/>
                <shacl:pattern>^[A-Z]{2}-[0-9]{3}$</shacl:pattern>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Warning"/>
            </rdf:Description>
        </shacl:property>
        <shacl:sparql>
            <rdf:Description>
                <shacl:message>OperatingEndDate must be greater than or equal to OperatingStartDate</shacl:message>
                <shacl:select>
            SELECT $this WHERE {
                $this hmis:OperatingStartDate ?start ;
                      hmis:OperatingEndDate ?end .
                FILTER(?end &lt; ?start)
            }
        </shacl:select>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:sparql>
        <shacl:targetClass rdf:resource="http://hmis.hud.gov/ontology#Project"/>
    </owl:NamedIndividual>
    


