    <!-- http://hmis.hud.gov/ontology#EnrollmentShape -->

    <owl:NamedIndividual rdf:about="http://hmis.hud.gov/ontology#EnrollmentShape">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <rdfs:comment>Validation rules for Enrollment entity</rdfs:comment>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                <shacl:maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:maxCount>
                <shacl:maxLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">32</shacl:maxLength>
                <shacl:message>EnrollmentID is required and must be 1-32 characters</shacl:message>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:minLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minLength>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#EnrollmentID"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
                <shacl:maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:maxCount>
                <shacl:message>EntryDate is required</shacl:message>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#EntryDate"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                <shacl:maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:maxCount>
                <shacl:message>HouseholdID is required</shacl:message>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#HouseholdID"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                <shacl:maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:maxCount>
                <shacl:minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:minCount>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#RelationshipToHoH"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
                <shacl:sparql>
                    <rdf:Description>
                        <shacl:message>RelationshipToHoH value {$value} is invalid. Must be from RelationshipScheme (1-5).</shacl:message>
                        <shacl:select>
                SELECT $this ?value WHERE {
                    $this hmis:RelationshipToHoH ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:RelationshipScheme ;
                                 skos:notation ?value .
                    }
                }
            </shacl:select>
                    </rdf:Description>
                </shacl:sparql>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                <shacl:message>EnrollmentCoC must be in format XX-NNN (e.g., CA-500)</shacl:message>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#EnrollmentCoC"/>
                <shacl:pattern>^[A-Z]{2}-[0-9]{3}$</shacl:pattern>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Info"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Warning"/>
                <shacl:sparql>
                    <rdf:Description>
                        <shacl:message>EnrollmentCoC value {$value} is not a recognized CoC code.</shacl:message>
                        <shacl:select>
                SELECT $this ?value WHERE {
                    $this hmis:EnrollmentCoC ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:CoCScheme ;
                                 skos:notation ?value .
                    }
                }
            </shacl:select>
                    </rdf:Description>
                </shacl:sparql>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#DisablingCondition"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
                <shacl:sparql>
                    <rdf:Description>
                        <shacl:message>DisablingCondition value {$value} is invalid. Must be from YesNoReasonsScheme.</shacl:message>
                        <shacl:select>
                SELECT $this ?value WHERE {
                    $this hmis:DisablingCondition ?value .
                    FILTER NOT EXISTS {
                        ?concept skos:inScheme hmis:YesNoReasonsScheme ;
                                 skos:notation ?value .
                    }
                }
            </shacl:select>
                    </rdf:Description>
                </shacl:sparql>
            </rdf:Description>
        </shacl:property>
        <shacl:property>
            <rdf:Description>
                <shacl:datatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                <shacl:path rdf:resource="http://hmis.hud.gov/ontology#Destination"/>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
                <shacl:sparql>
                    <rdf:Description>
                        <shacl:message>Destination value {$value} is invalid. Must be from DestinationScheme.</shacl:message>
                        <shacl:select>
                SELECT $this ?value WHERE {
                    $this hmis:Destination ?value .
                    FILTER NOT EXISTS {
                        ?concept skos:inScheme hmis:DestinationScheme ;
                                 skos:notation ?value .
                    }
                }
            </shacl:select>
                    </rdf:Description>
                </shacl:sparql>
            </rdf:Description>
        </shacl:property>
        <shacl:sparql>
            <rdf:Description>
                <shacl:message>EntryDate cannot be in the future</shacl:message>
                <shacl:select>
            SELECT $this WHERE {
                $this hmis:EntryDate ?entry .
                FILTER(?entry &gt; NOW())
            }
        </shacl:select>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:sparql>
        <shacl:sparql>
            <rdf:Description>
                <shacl:message>ExitDate must be greater than or equal to EntryDate</shacl:message>
                <shacl:select>
            SELECT $this WHERE {
                $this hmis:EntryDate ?entry ;
                      hmis:ExitDate ?exit .
                FILTER(?exit &lt; ?entry)
            }
        </shacl:select>
                <shacl:severity rdf:resource="http://www.w3.org/ns/shacl#Violation"/>
            </rdf:Description>
        </shacl:sparql>
        <shacl:targetClass rdf:resource="http://hmis.hud.gov/ontology#Enrollment"/>
    </owl:NamedIndividual>
    


