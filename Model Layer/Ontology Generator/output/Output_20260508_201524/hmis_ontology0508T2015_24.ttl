hmis:"DOBDataQuality" a skos:ConceptScheme ;
  skos:prefLabel "DOBDataQuality" ;
  hmis:csvList "3.03.2" .

hmis:"Living Situation Option List" a skos:ConceptScheme ;
  skos:prefLabel "Living Situation Option List" ;
  hmis:csvList "3.12.1" .

hmis:"RentalSubsidyTypes" a skos:ConceptScheme ;
  skos:prefLabel "RentalSubsidyTypes" ;
  hmis:csvList "3.12.A" .

hmis:"RelationshipToHoH" a skos:ConceptScheme ;
  skos:prefLabel "RelationshipToHoH" ;
  hmis:csvList "3.15.1" .

hmis:"LengthOfStay" a skos:ConceptScheme ;
  skos:prefLabel "LengthOfStay" ;
  hmis:csvList "3.917.2" .

hmis:"TimesHomelessPastThreeYears" a skos:ConceptScheme ;
  skos:prefLabel "TimesHomelessPastThreeYears" ;
  hmis:csvList "3.917.4" .

hmis:"MonthsHomelessPastThreeYears" a skos:ConceptScheme ;
  skos:prefLabel "MonthsHomelessPastThreeYears" ;
  hmis:csvList "3.917.5" .

hmis:"ReasonNotInsured" a skos:ConceptScheme ;
  skos:prefLabel "ReasonNotInsured" ;
  hmis:csvList "4.04.A" .

hmis:"DisabilityResponse" a skos:ConceptScheme ;
  skos:prefLabel "DisabilityResponse" ;
  hmis:csvList "4.10.2" .

hmis:"WhenDVOccurred" a skos:ConceptScheme ;
  skos:prefLabel "WhenDVOccurred" ;
  hmis:csvList "4.11.A" .

hmis:"BedNight" a skos:ConceptScheme ;
  skos:prefLabel "BedNight" ;
  hmis:csvList "4.1399999999999997" .

