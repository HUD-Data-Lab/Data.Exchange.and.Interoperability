  skos:prefLabel "FundingSource" ;
  hmis:csvList "2.06.1" .

hmis:"HouseholdType" a skos:ConceptScheme ;
  skos:prefLabel "HouseholdType" ;
  hmis:csvList "2.07.4" .

hmis:"BedType" a skos:ConceptScheme ;
  skos:prefLabel "BedType" ;
  hmis:csvList "2.07.5" .

hmis:"Availability" a skos:ConceptScheme ;
  skos:prefLabel "Availability" ;
  hmis:csvList "2.07.6" .

hmis:"TargetPopulation" a skos:ConceptScheme ;
  skos:prefLabel "TargetPopulation" ;
  hmis:csvList "2.02.7" .

hmis:"HOPWAMedAssistedLivingFac" a skos:ConceptScheme ;
  skos:prefLabel "HOPWAMedAssistedLivingFac" ;
  hmis:csvList "2.02.8" .

hmis:"GeographyType" a skos:ConceptScheme ;
  skos:prefLabel "GeographyType" ;
  hmis:csvList "2.03.4" .

hmis:"HMISParticipationType" a skos:ConceptScheme ;
  skos:prefLabel "HMISParticipationType" ;
  hmis:csvList "2.08.1" .

hmis:"NameDataQuality" a skos:ConceptScheme ;
  skos:prefLabel "NameDataQuality" ;
  hmis:csvList "3.01.5" .

hmis:"SSNDataQuality" a skos:ConceptScheme ;
  skos:prefLabel "SSNDataQuality" ;
