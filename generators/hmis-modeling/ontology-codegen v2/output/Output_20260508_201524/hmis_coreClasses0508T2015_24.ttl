@prefix hmis: <http://www.semanticweb.org/61084/ontologies/2026/2/hmis#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

hmis:Client a owl:Class ;
  rdfs:label "Client" ;
  rdfs:comment "Person receiving homeless services" ;
  owl:disjointWith hmis:Project ,
                   hmis:SubEnrollment ,
                   hmis:User ,
                   hmis:SubCEAssessment ,
                   hmis:Organization ,
                   hmis:SubEnrollAssessment ,
                   hmis:Enrollment ,
                   hmis:Household ,
                   hmis:SubProject .

hmis:Enrollment a owl:Class ;
  rdfs:label "Enrollment" ;
  rdfs:comment "Episode of service delivery for a client in a project" ;
  owl:disjointWith hmis:Project ,
                   hmis:SubEnrollment ,
                   hmis:User ,
                   hmis:SubCEAssessment ,
                   hmis:Client ,
                   hmis:Organization ,
                   hmis:SubEnrollAssessment ,
                   hmis:Household ,
                   hmis:SubProject .

hmis:Household a owl:Class ;
  rdfs:label "Household" ;
  rdfs:comment "Group of related clients enrolled together" ;
  owl:disjointWith hmis:Project ,
                   hmis:SubEnrollment ,
                   hmis:User ,
                   hmis:SubCEAssessment ,
                   hmis:Client ,
                   hmis:Organization ,
                   hmis:SubEnrollAssessment ,
                   hmis:Enrollment ,
                   hmis:SubProject .

hmis:Organization a owl:Class ;
  rdfs:label "Organization" ;
  rdfs:comment "Agency operating homeless services projects" ;
  owl:disjointWith hmis:Project ,
                   hmis:SubEnrollment ,
                   hmis:User ,
                   hmis:SubCEAssessment ,
                   hmis:Client ,
                   hmis:SubEnrollAssessment ,
                   hmis:Enrollment ,
                   hmis:Household ,
                   hmis:SubProject .

hmis:Project a owl:Class ;
  rdfs:label "Project" ;
  rdfs:comment "Service program or location" ;
  owl:disjointWith hmis:SubEnrollment ,
                   hmis:User ,
                   hmis:SubCEAssessment ,
                   hmis:Client ,
                   hmis:Organization ,
                   hmis:SubEnrollAssessment ,
                   hmis:Enrollment ,
                   hmis:Household ,
                   hmis:SubProject .

hmis:SubCEAssessment a owl:Class ;
  owl:disjointWith hmis:Project ,
                   hmis:SubEnrollment ,
                   hmis:User ,
                   hmis:Client ,
                   hmis:Organization ,
                   hmis:SubEnrollAssessment ,
                   hmis:Enrollment ,
                   hmis:Household ,
                   hmis:SubProject .

hmis:SubEnrollAssessment a owl:Class ;
  rdfs:comment "What differentiates these from SubCEAssessment is that these will inherit the data collection stage, whereas data collection stage does not apply to CE Assessments or their subcomponents." ;
  rdfs:subClassOf hmis:SubEnrollment ;
  owl:disjointWith hmis:Project ,
                   hmis:SubEnrollment ,
                   hmis:User ,
                   hmis:SubCEAssessment ,
                   hmis:Client ,
                   hmis:Organization ,
                   hmis:Enrollment ,
                   hmis:Household ,
                   hmis:SubProject .

hmis:SubEnrollment a owl:Class ;
  rdfs:label "Sub-Enrollment" ;
  rdfs:comment "Abstract class for data collected during an enrollment (assessments, services, etc.)" ;
  owl:disjointWith hmis:Project ,
                   hmis:User ,
                   hmis:SubCEAssessment ,
                   hmis:Client ,
                   hmis:Organization ,
                   hmis:SubEnrollAssessment ,
                   hmis:Enrollment ,
                   hmis:Household ,
                   hmis:SubProject .

hmis:SubProject a owl:Class ;
  rdfs:label "Configuration" ;
  rdfs:comment "Abstract class for project configuration data (inventory, funding, CE participation, HMIS participation)" ;
  owl:disjointWith hmis:Project ,
                   hmis:SubEnrollment ,
                   hmis:User ,
                   hmis:SubCEAssessment ,
                   hmis:Client ,
                   hmis:Organization ,
                   hmis:SubEnrollAssessment ,
                   hmis:Enrollment ,
                   hmis:Household .

hmis:User a owl:Class ;
  owl:disjointWith hmis:Project ,
                   hmis:SubEnrollment ,
                   hmis:SubCEAssessment ,
                   hmis:Client ,
                   hmis:Organization ,
                   hmis:SubEnrollAssessment ,
                   hmis:Enrollment ,
                   hmis:Household ,
                   hmis:SubProject .

hmis:CEQuestion a owl:Class ;
  rdfs:subClassOf hmis:SubCEAssessment ;
  owl:disjointWith hmis:CEResult .

hmis:CEResult a owl:Class ;
  rdfs:subClassOf hmis:SubCEAssessment ;
  owl:disjointWith hmis:CEQuestion .

hmis:Benefit a owl:Class ;
  rdfs:subClassOf hmis:SubEnrollAssessment ;
  owl:disjointWith hmis:Disability ,
                   hmis:HealthInsurance ,
                   hmis:Income .

hmis:Disability a owl:Class ;
  rdfs:subClassOf hmis:SubEnrollAssessment ;
  owl:disjointWith hmis:Benefit ,
                   hmis:HealthInsurance ,
                   hmis:Income .

hmis:HealthInsurance a owl:Class ;
  rdfs:subClassOf hmis:SubEnrollAssessment ;
  owl:disjointWith hmis:Benefit ,
                   hmis:Disability ,
                   hmis:Income .

hmis:Income a owl:Class ;
  rdfs:subClassOf hmis:SubEnrollAssessment ;
  owl:disjointWith hmis:Benefit ,
                   hmis:Disability ,
                   hmis:HealthInsurance .

hmis:CEAssessment a owl:Class ;
  rdfs:subClassOf hmis:SubEnrollment ;
  owl:disjointWith hmis:CEEvent ,
                   hmis:CurrentLivingSituation ,
                   hmis:EnrollAssessment ,
                   hmis:Service .

hmis:CEEvent a owl:Class ;
  rdfs:label "Current Living Situation" ;
  rdfs:comment "Point-in-time record of where client is currently staying" ;
  rdfs:subClassOf hmis:SubEnrollment ;
  owl:disjointWith hmis:CEAssessment ,
                   hmis:CurrentLivingSituation ,
                   hmis:EnrollAssessment ,
                   hmis:Service .

hmis:CurrentLivingSituation a owl:Class ;
  rdfs:subClassOf hmis:SubEnrollment ;
  owl:disjointWith hmis:CEAssessment ,
                   hmis:CEEvent ,
                   hmis:EnrollAssessment ,
                   hmis:Service .

hmis:EnrollAssessment a owl:Class ;
  rdfs:label "Assessment" ;
  rdfs:comment "Data collecttion point during enrollment (entry,update,annual, exit, post-exit)" ;
  rdfs:subClassOf hmis:SubEnrollment ;
  owl:disjointWith hmis:CEAssessment ,
                   hmis:CEEvent ,
                   hmis:CurrentLivingSituation ,
                   hmis:Service .

hmis:Service a owl:Class ;
  rdfs:label "Service" ;
  rdfs:comment "Service provided to client during enrollment" ;
  rdfs:subClassOf hmis:SubEnrollment ;
  owl:disjointWith hmis:CEAssessment ,
                   hmis:CEEvent ,
                   hmis:CurrentLivingSituation ,
                   hmis:EnrollAssessment .

hmis:CEParticipation a owl:Class ;
  rdfs:label "Coordinated Entry Participation" ;
  rdfs:comment "Records a project's participation in the coordinated Entry system, including access points and referral mechanisms" ;
  rdfs:subClassOf hmis:SubProject ;
  owl:disjointWith hmis:FundSource ,
                   hmis:Geography ,
                   hmis:HMISParticipation ,
                   hmis:Inventory .

hmis:FundSource a owl:Class ;
  rdfs:label "Funder" ;
  rdfs:comment "Funding source for a project (CoC,ESG,HOPWA,etc)" ;
  rdfs:subClassOf hmis:SubProject ;
  owl:disjointWith hmis:CEParticipation ,
                   hmis:Geography ,
                   hmis:HMISParticipation ,
                   hmis:Inventory .

hmis:Geography a owl:Class ;
  rdfs:subClassOf hmis:SubProject ;
  owl:disjointWith hmis:CEParticipation ,
                   hmis:FundSource ,
                   hmis:HMISParticipation ,
                   hmis:Inventory .

hmis:HMISParticipation a owl:Class ;
  rdfs:label "HMIS Participation" ;
  rdfs:comment "Records a project's participation in the HMIS system, including participation type and status dates" ;
  rdfs:subClassOf hmis:SubProject ;
  owl:disjointWith hmis:CEParticipation ,
                   hmis:FundSource ,
                   hmis:Geography ,
                   hmis:Inventory .

hmis:Inventory a owl:Class ;
  rdfs:label "Inventory" ;
  rdfs:comment "Beds,units,and rooms available in project" ;
  rdfs:subClassOf hmis:SubProject ;
  owl:disjointWith hmis:CEParticipation ,
                   hmis:FundSource ,
                   hmis:Geography ,
                   hmis:HMISParticipation .

hmis:clientOf a owl:ObjectProperty ;
  owl:inverseOf hmis:hasClient ;
  rdfs:domain hmis:Client ;
  rdfs:range hmis:Enrollment ;
  rdfs:label "has enrollment"@en ;
rdfs:comment "Links a client to their enrollment"@en .

hmis:configurationOf a owl:ObjectProperty ;
  owl:inverseOf hmis:hasConfiguration ;
  rdfs:domain hmis:SubProject ;
  rdfs:range hmis:Project ;
  rdfs:label "configures"@en ;
rdfs:comment "Links a sub-project configuration to the project it configures"@en .

hmis:ceParticipationOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:configurationOf ;
  owl:inverseOf hmis:hasCEParticipation ;
  rdfs:domain hmis:CEParticipation ;
  rdfs:range hmis:Project ;
  rdfs:label "CE participation of"@en ;
rdfs:comment "links a CE participation record to its project"@en .

hmis:fundSourceOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:configurationOf ;
  owl:inverseOf hmis:hasFundSource ;
  rdfs:domain hmis:FundSource ;
  rdfs:range hmis:Project ;
  rdfs:label "fund source of"@en ;
rdfs:comment "Links a funding source to the project it funds"@en .

hmis:geographyOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:configurationOf ;
owl:inverseOf hmis:hasGeography .

hmis:hmisParticipationOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:configurationOf ;
  owl:inverseOf hmis:hasHMISParticipation ;
  rdfs:domain hmis:HMISParticipation ;
  rdfs:range hmis:Project ;
  rdfs:label "HMIS participation of"@en ;
rdfs:comment "Links an HMIS participation record to its project"@en .

hmis:inventoryOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:configurationOf ;
owl:inverseOf hmis:hasInventory .

hmis:hasClient a owl:ObjectProperty ;
  owl:inverseOf hmis:clientOf ;
  rdfs:domain hmis:Enrollment ;
  rdfs:range hmis:Client ;
  rdfs:label "enrollment of"@en ;
rdfs:comment "Links an enrollment to the client enrolled"@en .

hmis:hasConfiguration a owl:ObjectProperty ;
  owl:inverseOf hmis:configurationOf ;
  rdfs:domain hmis:Project ;
  rdfs:range hmis:SubProject ;
  rdfs:label "has configuration"@en ;
rdfs:comment "Links a project to its configuration data"@en .

hmis:hasCEParticipation a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasConfiguration ;
  owl:inverseOf hmis:ceParticipationOf ;
  rdfs:domain hmis:Project ;
  rdfs:range hmis:CEParticipation ;
  rdfs:label "has CE participation"@en ;
rdfs:comment "Links a project to its Coordinated Entry participation record"@en .

hmis:hasFundSource a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasConfiguration ;
  owl:inverseOf hmis:fundSourceOf ;
  rdfs:domain hmis:Project ;
  rdfs:range hmis:FundSource ;
  rdfs:label "has fund source"@en ;
rdfs:comment "Links a project to its funding source"@en .

hmis:hasGeography a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasConfiguration ;
  owl:inverseOf hmis:geographyOf ;
  rdfs:domain hmis:Project ;
rdfs:range hmis:Geography .

hmis:hasHMISParticipation a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasConfiguration ;
  owl:inverseOf hmis:hmisParticipationOf ;
  rdfs:domain hmis:Project ;
  rdfs:range hmis:HMISParticipation ;
  rdfs:label "has HMIS participation"@en ;
rdfs:comment "Links a project to its HMIS participation record"@en .

hmis:hasInventory a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasConfiguration ;
  owl:inverseOf hmis:inventoryOf ;
  rdfs:domain hmis:Project ;
rdfs:range hmis:Inventory .

hmis:hasHousehold a owl:ObjectProperty ;
  owl:inverseOf hmis:householdOf ;
  rdfs:domain hmis:Household ;
rdfs:range hmis:Enrollment .

hmis:hasMeasurement a owl:ObjectProperty ;
  owl:inverseOf hmis:measurementOf ;
  rdfs:domain hmis:CEAssessment ;
rdfs:range hmis:SubCEAssessment .

hmis:hasCEQuestion a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasMeasurement ;
  owl:inverseOf hmis:ceQuestionOf ;
  rdfs:domain hmis:CEAssessment ;
rdfs:range hmis:CEQuestion .

hmis:hasCEResult a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasMeasurement ;
  owl:inverseOf hmis:ceResultOf ;
  rdfs:domain hmis:CEAssessment ;
rdfs:range hmis:CEResult .

hmis:hasOrganization a owl:ObjectProperty ;
  owl:inverseOf hmis:organizationOf ;
  rdfs:domain hmis:Project ;
  rdfs:range hmis:Organization ;
  rdfs:label "operated by"@en ;
rdfs:comment "Links a project to the organization operating it"@en .

hmis:hasPart a owl:ObjectProperty ;
  owl:inverseOf hmis:partOf ;
  rdfs:domain hmis:Enrollment ;
  rdfs:range hmis:SubEnrollment ;
  rdfs:label "has sub-enrollment"@en ;
rdfs:comment "Links an enrollment to events that occurred during it"@en .

hmis:hasCEAssessment a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
  owl:inverseOf hmis:ceAssessmentOf ;
  rdfs:domain hmis:Enrollment ;
rdfs:range hmis:CEAssessment .

hmis:hasCEEvent a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
  owl:inverseOf hmis:ceEventOf ;
  rdfs:domain hmis:Enrollment ;
rdfs:range hmis:CEEvent .

hmis:hasCurrentLivingSituation a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
  owl:inverseOf hmis:currentLivingSituationOf ;
  rdfs:domain hmis:Enrollment ;
rdfs:range hmis:CurrentLivingSituation .

hmis:hasEnrollAssessment a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
  owl:inverseOf hmis:enrollAssessmentOf ;
  rdfs:domain hmis:Enrollment ;
rdfs:range hmis:EnrollAssessment .

hmis:hasService a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
  owl:inverseOf hmis:serviceOf ;
  rdfs:domain hmis:Enrollment ;
rdfs:range hmis:Service .

hmis:hasProject a owl:ObjectProperty ;
  owl:inverseOf hmis:projectOf ;
  rdfs:domain hmis:Enrollment ;
rdfs:range hmis:Project .

hmis:hasResidentialAffiliation a owl:ObjectProperty ;
  owl:inverseOf hmis:residentiallyAffiliatedWith ;
  rdfs:domain hmis:Project ;
rdfs:range hmis:Project .

hmis:hasSubpart a owl:ObjectProperty ;
  owl:inverseOf hmis:subPartOf ;
  rdfs:domain hmis:EnrollAssessment ;
rdfs:range hmis:SubEnrollAssessment .

hmis:hasBenefit a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasSubpart ;
  owl:inverseOf hmis:benefitOf ;
  rdfs:domain hmis:EnrollAssessment ;
rdfs:range hmis:Benefit .

hmis:hasDisability a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasSubpart ;
  owl:inverseOf hmis:disabilityOf ;
  rdfs:domain hmis:EnrollAssessment ;
rdfs:range hmis:Disability .

hmis:hasHealthInsurance a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasSubpart ;
  owl:inverseOf hmis:healthInsuranceOf ;
  rdfs:domain hmis:EnrollAssessment ;
rdfs:range hmis:HealthInsurance .

hmis:hasIncome a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasSubpart ;
  owl:inverseOf hmis:incomeOf ;
  rdfs:domain hmis:EnrollAssessment ;
rdfs:range hmis:Income .

hmis:householdOf a owl:ObjectProperty ;
  owl:inverseOf hmis:hasHousehold ;
  rdfs:domain hmis:Enrollment ;
  rdfs:range hmis:Household ;
  rdfs:label "member of"@en ;
rdfs:comment "Links an enrollment to its household"@en .

hmis:measurementOf a owl:ObjectProperty ;
owl:inverseOf hmis:hasMeasurement .

hmis:ceQuestionOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:measurementOf ;
owl:inverseOf hmis:hasCEQuestion .

hmis:ceResultOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:measurementOf ;
owl:inverseOf hmis:hasCEResult .

hmis:organizationOf a owl:ObjectProperty ;
  owl:inverseOf hmis:hasOrganization ;
  rdfs:domain hmis:Organization ;
  rdfs:range hmis:Project ;
  rdfs:label "operates"@en ;
rdfs:comment "Links an organization to projects it operates"@en .

hmis:partof a owl:ObjectProperty ;
  owl:inverseOf hmis:hasPart ;
  rdfs:domain hmis:SubEnrollment ;
  rdfs:range hmis:Enrollment ;
  rdfs:label "during"@en ;
rdfs:comment "Links a sub-enrollment event to the enrollment it occurred during"@en .

hmis:ceAssessmentOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
owl:inverseOf hmis:hasCEAssessment .

hmis:ceEventOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
owl:inverseOf hmis:hasCEEvent .

hmis:currentLivingSituationOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
owl:inverseOf hmis:hasCurrentLivingSituation .

hmis:enrollAssessmentOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
owl:inverseOf hmis:hasEnrollAssessment .

hmis:serviceOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:hasPart ;
owl:inverseOf hmis:hasService .

hmis:projectOf a owl:ObjectProperty ;
  owl:inverseOf hmis:hasProject ;
  rdfs:domain hmis:Project ;
  rdfs:range hmis:Enrollment ;
  rdfs:label "project of"@en ;
rdfs:comment "Links a project to enrollment within it"@en .

hmis:residentiallyAffiliatedWith a owl:ObjectProperty ;
  owl:inverseOf hmis:hasResidentialAffiliation ;
rdfs:comment "Intention is that this would be a property limited to SSOs, whereas the inverse would be limited to residential projects."@en .

hmis:subPartOf a owl:ObjectProperty ;
  owl:inverseOf hmis:hasSubpart ;
  rdfs:domain hmis:SubEnrollAssessment ;
rdfs:range hmis:EnrollAssessment .

hmis:benefitOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:subPartOf ;
  owl:inverseOf hmis:hasBenefit ;
  rdfs:domain hmis:Benefit ;
rdfs:range hmis:EnrollAssessment .

hmis:disabilityOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:subPartOf ;
  owl:inverseOf hmis:hasDisability ;
  rdfs:domain hmis:Disability ;
rdfs:range hmis:EnrollAssessment .

hmis:healthInsuranceOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:subPartOf ;
  owl:inverseOf hmis:hasHealthInsurance ;
  rdfs:domain hmis:HealthInsurance ;
rdfs:range hmis:EnrollAssessment .

hmis:incomeOf a owl:ObjectProperty ;
  rdfs:subPropertyOf hmis:subPartOf ;
  owl:inverseOf hmis:hasIncome ;
  rdfs:domain hmis:Income ;
rdfs:range hmis:EnrollAssessment .

