   shacl:severity shacl:Violation ;
   shacl:sparql [ shacl:message "Gender value {$value} is invalid. Must be from GenderScheme (0-6, 8, 9, or 99)." ;
                  shacl:select """
                SELECT $this ?value WHERE {
                    $this hmis:Gender ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:GenderScheme ;
                                 skos:notation ?value .
                    }
                }
            """
                ]
 ] .

[ shacl:datatype xsd:string ;
