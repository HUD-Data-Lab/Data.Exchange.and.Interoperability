[ shacl:message "Homelessness Prevention enrollments (ProjectType 12) must have DateOfEngagement." ;
   shacl:select """
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:inProject ?project .
                ?project hmis:ProjectType 12 .
                
                FILTER NOT EXISTS {
                    $this hmis:DateOfEngagement ?date .
