[ shacl:message "Household {$this} must have exactly one member with RelationshipToHoH = 1 (Self)." ;
   shacl:select """
            SELECT $this (COUNT(?hoh) as ?hohCount) WHERE {
                $this a hmis:Household ;
                      hmis:hasMember ?enrollment .
                ?enrollment hmis:RelationshipToHoH 1 .
            }
            GROUP BY $this
            HAVING (?hohCount != 1)
        """ ;
   shacl:severity shacl:Violation
 ] .

