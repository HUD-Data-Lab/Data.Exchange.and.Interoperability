[ shacl:datatype xsd:string ;
  shacl:message "EnrollmentCoC must be in format XX-NNN (e.g., CA-500)" ;
  shacl:pattern "^[A-Z]{2}-[0-9]{3}$" ;
  shacl:severity shacl:Info ,
                 shacl:Warning ;
  shacl:sparql [ shacl:message "EnrollmentCoC value {$value} is not a recognized CoC code." ;
                 shacl:select """
                SELECT $this ?value WHERE {
                    $this hmis:EnrollmentCoC ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:CoCScheme ;
                                 skos:notation ?value .
                    }
                }
            """
               ]
] .

[ shacl:datatype xsd:integer ;
   shacl:maxCount 1 ;
   shacl:minCount 1 ;
   shacl:severity shacl:Violation ;
   shacl:sparql [ shacl:message "RelationshipToHoH value {$value} is invalid. Must be from RelationshipScheme (1-5)." ;
                  shacl:select """
                SELECT $this ?value WHERE {
                    $this hmis:RelationshipToHoH ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:RelationshipScheme ;
                                 skos:notation ?value .
                    }
                }
            """
                ]
 ] .

[ shacl:message "ExitDate must be greater than or equal to EntryDate" ;
   shacl:select """
            SELECT $this WHERE {
                $this hmis:EntryDate ?entry ;
                      hmis:ExitDate ?exit .
                FILTER(?exit < ?entry)
            }
        """ ;
   shacl:severity shacl:Violation
 ] .

[ shacl:message "EntryDate cannot be in the future" ;
   shacl:select """
            SELECT $this WHERE {
                $this hmis:EntryDate ?entry .
                FILTER(?entry > NOW())
            }
        """ ;
   shacl:severity shacl:Violation
 ] .

[ shacl:datatype xsd:integer ;
