[ shacl:message "Enrollment has been open for over 1 year without exit. Verify enrollment is still active." ;
   shacl:select """
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:EntryDate ?entry .
                FILTER NOT EXISTS { $this hmis:ExitDate ?exit }
                FILTER(?entry < NOW() - \"P365D\"^^xsd:duration)
            }
        """ ;
   shacl:severity shacl:Info
 ] .

[ shacl:message "Services Only enrollments (ProjectType 6) must have DateOfEngagement." ;
   shacl:select """
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:inProject ?project .
                ?project hmis:ProjectType 6 .
                
                FILTER NOT EXISTS {
                    $this hmis:DateOfEngagement ?date .
                }
            }
        """ ;
   shacl:severity shacl:Violation
 ] .

