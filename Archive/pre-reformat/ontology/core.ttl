#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://hmis.hud.gov/ontology#ceParticipationOf
<http://hmis.hud.gov/ontology#ceParticipationOf> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <http://hmis.hud.gov/ontology#configurationOf> ;
                                                 owl:inverseOf <http://hmis.hud.gov/ontology#hasCEParticipation> ;
                                                 rdfs:domain <http://hmis.hud.gov/ontology#CEParticipation> ;
                                                 rdfs:range <http://hmis.hud.gov/ontology#Project> ;
                                                 rdfs:comment "Links a CE participation record to its project"@en ;
                                                 rdfs:label "CE participation of"@en .


###  http://hmis.hud.gov/ontology#clientOf
<http://hmis.hud.gov/ontology#clientOf> rdf:type owl:ObjectProperty ;
                                        owl:inverseOf <http://hmis.hud.gov/ontology#hasClient> ;
                                        rdfs:domain <http://hmis.hud.gov/ontology#Client> ;
                                        rdfs:range <http://hmis.hud.gov/ontology#Enrollment> ;
                                        rdfs:comment "Links a client to their enrollments"@en ;
                                        rdfs:label "has enrollment"@en .


###  http://hmis.hud.gov/ontology#configurationOf
<http://hmis.hud.gov/ontology#configurationOf> rdf:type owl:ObjectProperty ;
                                               owl:inverseOf <http://hmis.hud.gov/ontology#hasConfiguration> ;
                                               rdfs:domain <http://hmis.hud.gov/ontology#SubProject> ;
                                               rdfs:range <http://hmis.hud.gov/ontology#Project> ;
                                               rdfs:comment "Links a sub-project configuration to the project it configures"@en ;
                                               rdfs:label "configures"@en .


###  http://hmis.hud.gov/ontology#fundSourceOf
<http://hmis.hud.gov/ontology#fundSourceOf> rdf:type owl:ObjectProperty ;
                                            rdfs:subPropertyOf <http://hmis.hud.gov/ontology#configurationOf> ;
                                            owl:inverseOf <http://hmis.hud.gov/ontology#hasFundSource> ;
                                            rdfs:domain <http://hmis.hud.gov/ontology#FundSource> ;
                                            rdfs:range <http://hmis.hud.gov/ontology#Project> ;
                                            rdfs:comment "Links a funding source to the project it funds"@en ;
                                            rdfs:label "fund source of"@en .


###  http://hmis.hud.gov/ontology#hasCEParticipation
<http://hmis.hud.gov/ontology#hasCEParticipation> rdf:type owl:ObjectProperty ;
                                                  rdfs:subPropertyOf <http://hmis.hud.gov/ontology#hasConfiguration> ;
                                                  rdfs:domain <http://hmis.hud.gov/ontology#Project> ;
                                                  rdfs:range <http://hmis.hud.gov/ontology#CEParticipation> ;
                                                  rdfs:comment "Links a project to its Coordinated Entry participation record"@en ;
                                                  rdfs:label "has CE participation"@en .


###  http://hmis.hud.gov/ontology#hasClient
<http://hmis.hud.gov/ontology#hasClient> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <http://hmis.hud.gov/ontology#Enrollment> ;
                                         rdfs:range <http://hmis.hud.gov/ontology#Client> ;
                                         rdfs:comment "Links an enrollment to the client enrolled"@en ;
                                         rdfs:label "enrollment of"@en .


###  http://hmis.hud.gov/ontology#hasConfiguration
<http://hmis.hud.gov/ontology#hasConfiguration> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <http://hmis.hud.gov/ontology#Project> ;
                                                rdfs:range <http://hmis.hud.gov/ontology#SubProject> ;
                                                rdfs:comment "Links a project to its configuration data"@en ;
                                                rdfs:label "has configuration"@en .


###  http://hmis.hud.gov/ontology#hasFundSource
<http://hmis.hud.gov/ontology#hasFundSource> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <http://hmis.hud.gov/ontology#hasConfiguration> ;
                                             rdfs:domain <http://hmis.hud.gov/ontology#Project> ;
                                             rdfs:range <http://hmis.hud.gov/ontology#FundSource> ;
                                             rdfs:comment "Links a project to its funding sources"@en ;
                                             rdfs:label "has fund source"@en .


###  http://hmis.hud.gov/ontology#hasHMISParticipation
<http://hmis.hud.gov/ontology#hasHMISParticipation> rdf:type owl:ObjectProperty ;
                                                    rdfs:subPropertyOf <http://hmis.hud.gov/ontology#hasConfiguration> ;
                                                    owl:inverseOf <http://hmis.hud.gov/ontology#hmisParticipationOf> ;
                                                    rdfs:domain <http://hmis.hud.gov/ontology#Project> ;
                                                    rdfs:range <http://hmis.hud.gov/ontology#HMISParticipation> ;
                                                    rdfs:comment "Links a project to its HMIS participation record"@en ;
                                                    rdfs:label "has HMIS participation"@en .


###  http://hmis.hud.gov/ontology#hasHousehold
<http://hmis.hud.gov/ontology#hasHousehold> rdf:type owl:ObjectProperty ;
                                            owl:inverseOf <http://hmis.hud.gov/ontology#householdOf> ;
                                            rdfs:domain <http://hmis.hud.gov/ontology#Household> ;
                                            rdfs:range <http://hmis.hud.gov/ontology#Enrollment> ;
                                            rdfs:comment "Links a household to member enrollments"@en ;
                                            rdfs:label "has member"@en .


###  http://hmis.hud.gov/ontology#hasOrganization
<http://hmis.hud.gov/ontology#hasOrganization> rdf:type owl:ObjectProperty ;
                                               owl:inverseOf <http://hmis.hud.gov/ontology#organizationOf> ;
                                               rdfs:domain <http://hmis.hud.gov/ontology#Project> ;
                                               rdfs:range <http://hmis.hud.gov/ontology#Organization> ;
                                               rdfs:comment "Links a project to the organization operating it"@en ;
                                               rdfs:label "operated by"@en .


###  http://hmis.hud.gov/ontology#hasPart
<http://hmis.hud.gov/ontology#hasPart> rdf:type owl:ObjectProperty ;
                                       owl:inverseOf <http://hmis.hud.gov/ontology#partOf> ;
                                       rdfs:domain <http://hmis.hud.gov/ontology#Enrollment> ;
                                       rdfs:range <http://hmis.hud.gov/ontology#SubEnrollment> ;
                                       rdfs:comment "Links an enrollment to events that occurred during it"@en ;
                                       rdfs:label "has sub-enrollment"@en .


###  http://hmis.hud.gov/ontology#hasProject
<http://hmis.hud.gov/ontology#hasProject> rdf:type owl:ObjectProperty ;
                                          owl:inverseOf <http://hmis.hud.gov/ontology#projectOf> ;
                                          rdfs:domain <http://hmis.hud.gov/ontology#Enrollment> ;
                                          rdfs:range <http://hmis.hud.gov/ontology#Project> ;
                                          rdfs:comment "Links an enrollment to the project providing services"@en ;
                                          rdfs:label "in project"@en .


###  http://hmis.hud.gov/ontology#hmisParticipationOf
<http://hmis.hud.gov/ontology#hmisParticipationOf> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <http://hmis.hud.gov/ontology#configurationOf> ;
                                                   rdfs:domain <http://hmis.hud.gov/ontology#HMISParticipation> ;
                                                   rdfs:range <http://hmis.hud.gov/ontology#Project> ;
                                                   rdfs:comment "Links an HMIS participation record to its project"@en ;
                                                   rdfs:label "HMIS participation of"@en .


###  http://hmis.hud.gov/ontology#householdOf
<http://hmis.hud.gov/ontology#householdOf> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <http://hmis.hud.gov/ontology#Enrollment> ;
                                           rdfs:range <http://hmis.hud.gov/ontology#Household> ;
                                           rdfs:comment "Links an enrollment to its household"@en ;
                                           rdfs:label "member of"@en .


###  http://hmis.hud.gov/ontology#organizationOf
<http://hmis.hud.gov/ontology#organizationOf> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <http://hmis.hud.gov/ontology#Organization> ;
                                              rdfs:range <http://hmis.hud.gov/ontology#Project> ;
                                              rdfs:comment "Links an organization to projects it operates"@en ;
                                              rdfs:label "operates"@en .


###  http://hmis.hud.gov/ontology#partOf
<http://hmis.hud.gov/ontology#partOf> rdf:type owl:ObjectProperty ;
                                      rdfs:domain <http://hmis.hud.gov/ontology#SubEnrollment> ;
                                      rdfs:range <http://hmis.hud.gov/ontology#Enrollment> ;
                                      rdfs:comment "Links a sub-enrollment event to the enrollment it occurred during"@en ;
                                      rdfs:label "during"@en .


###  http://hmis.hud.gov/ontology#projectOf
<http://hmis.hud.gov/ontology#projectOf> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <http://hmis.hud.gov/ontology#Project> ;
                                         rdfs:range <http://hmis.hud.gov/ontology#Enrollment> ;
                                         rdfs:comment "Links a project to enrollments within it"@en ;
                                         rdfs:label "project of"@en .


