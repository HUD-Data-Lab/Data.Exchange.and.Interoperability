<http://www.semanticweb.org/64257/ontologies/2026/2/hmis/ontology/core> rdf:type owl:Ontology ;
                                                                         owl:versionIRI <http://www.semanticweb.org/64257/ontologies/2026/2/hmis/ontology/core/v0.1> ;
                                                                         <http://purl.org/dc/terms/created> "2026-01-28"^^xsd:date ;
                                                                         <http://purl.org/dc/terms/creator> "ICF HMIS Team" ;
                                                                         <http://purl.org/dc/terms/description> "Core class and property definitions for HMIS data standards (FY2026)"@en ;
                                                                         <http://purl.org/dc/terms/modified> "2026-03-17" ;
                                                                         <http://purl.org/dc/terms/publisher> "U.S. Department of Housing and Urban Development" ;
                                                                         <http://purl.org/dc/terms/title> "HMIS Ontology - Structure Layer"@en ;
                                                                         rdfs:comment "This ontology defines the structural layer of HMIS data standards, including classes, object properties, and datatype properties. It is designed to work in conjunction with SKOS vocabularies (semantics) and SHACL constraints (validation)."@en ;
                                                                         owl:versionInfo "0.7" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


