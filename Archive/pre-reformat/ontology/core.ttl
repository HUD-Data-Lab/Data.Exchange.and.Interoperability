#################################################################
#    Classes
#################################################################

###  http://hmis.hud.gov/ontology#CEParticipation
<http://hmis.hud.gov/ontology#CEParticipation> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://hmis.hud.gov/ontology#SubProject> ;
                                               <http://purl.org/dc/terms/identifier> "4.19" ;
                                               rdfs:comment "Records a project's participation in the Coordinated Entry system, including access points and referral mechanisms"@en ;
                                               rdfs:label "Coordinated Entry Participation"@en .


###  http://hmis.hud.gov/ontology#Client
<http://hmis.hud.gov/ontology#Client> rdf:type owl:Class ;
                                      rdfs:comment "Person receiving homeless services"@en ;
                                      rdfs:label "Client"@en .


###  http://hmis.hud.gov/ontology#CurrentLivingSituation
<http://hmis.hud.gov/ontology#CurrentLivingSituation> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://hmis.hud.gov/ontology#SubEnrollment> ;
                                                      rdfs:comment "Point-in-time record of where client is currently staying"@en ;
                                                      rdfs:label "Current Living Situation"@en .


###  http://hmis.hud.gov/ontology#EnrollAssessment
<http://hmis.hud.gov/ontology#EnrollAssessment> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://hmis.hud.gov/ontology#SubEnrollment> ;
                                                rdfs:comment "Data collection point during enrollment (entry, update, annual, exit, post-exit)"@en ;
                                                rdfs:label "Assessment"@en .


###  http://hmis.hud.gov/ontology#Enrollment
<http://hmis.hud.gov/ontology#Enrollment> rdf:type owl:Class ;
                                          rdfs:comment "Episode of service delivery for a client in a project"@en ;
                                          rdfs:label "Enrollment"@en .


###  http://hmis.hud.gov/ontology#FundSource
<http://hmis.hud.gov/ontology#FundSource> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://hmis.hud.gov/ontology#SubProject> ;
                                          rdfs:comment "Funding source for a project (CoC, ESG, HOPWA, etc.)"@en ;
                                          rdfs:label "Funder"@en .


###  http://hmis.hud.gov/ontology#HMISParticipation
<http://hmis.hud.gov/ontology#HMISParticipation> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://hmis.hud.gov/ontology#SubProject> ;
                                                 <http://purl.org/dc/terms/identifier> "4.20" ;
                                                 rdfs:comment "Records a project's participation in the HMIS system, including participation type and status dates"@en ;
                                                 rdfs:label "HMIS Participation"@en .


###  http://hmis.hud.gov/ontology#Household
<http://hmis.hud.gov/ontology#Household> rdf:type owl:Class ;
                                         rdfs:comment "Group of related clients enrolled together"@en ;
                                         rdfs:label "Household"@en .


###  http://hmis.hud.gov/ontology#Inventory
<http://hmis.hud.gov/ontology#Inventory> rdf:type owl:Class ;
                                         rdfs:subClassOf <http://hmis.hud.gov/ontology#SubProject> ;
                                         rdfs:comment "Beds, units, and rooms available in project"@en ;
                                         rdfs:label "Inventory"@en .


###  http://hmis.hud.gov/ontology#Organization
<http://hmis.hud.gov/ontology#Organization> rdf:type owl:Class ;
                                            rdfs:comment "Agency operating homeless services projects"@en ;
                                            rdfs:label "Organization"@en .


###  http://hmis.hud.gov/ontology#Project
<http://hmis.hud.gov/ontology#Project> rdf:type owl:Class ;
                                       rdfs:comment "Service program or location"@en ;
                                       rdfs:label "Project"@en .


###  http://hmis.hud.gov/ontology#Service
<http://hmis.hud.gov/ontology#Service> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://hmis.hud.gov/ontology#SubEnrollment> ;
                                       rdfs:comment "Service provided to client during enrollment"@en ;
                                       rdfs:label "Service"@en .


###  http://hmis.hud.gov/ontology#SubEnrollment
<http://hmis.hud.gov/ontology#SubEnrollment> rdf:type owl:Class ;
                                             rdfs:comment "Abstract class for data collected during an enrollment (assessments, services, etc.)"@en ;
                                             rdfs:label "Sub-Enrollment"@en .


###  http://hmis.hud.gov/ontology#SubProject
<http://hmis.hud.gov/ontology#SubProject> rdf:type owl:Class ;
                                          rdfs:comment "Abstract class for project configuration data (inventory, funding, CE participation, HMIS participation)"@en ;
                                          rdfs:label "Configuration"@en .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#Benefit
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#Benefit> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubEnrollAssessment> .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#CEAssessment
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#CEAssessment> rdf:type owl:Class ;
                                                                                       rdfs:subClassOf <http://hmis.hud.gov/ontology#SubEnrollment> .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#CEEvent
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#CEEvent> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://hmis.hud.gov/ontology#SubEnrollment> .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#CEQuestion
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#CEQuestion> rdf:type owl:Class ;
                                                                                     rdfs:subClassOf <http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubCEAssessment> ;
                                                                                     owl:disjointWith <http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#CEResult> .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#CEResult
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#CEResult> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubCEAssessment> .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#Disability
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#Disability> rdf:type owl:Class ;
                                                                                     rdfs:subClassOf <http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubEnrollAssessment> .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#Geography
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#Geography> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://hmis.hud.gov/ontology#SubProject> .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#HealthInsurance
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#HealthInsurance> rdf:type owl:Class ;
                                                                                          rdfs:subClassOf <http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubEnrollAssessment> .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#Income
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#Income> rdf:type owl:Class ;
                                                                                 rdfs:subClassOf <http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubEnrollAssessment> .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubCEAssessment
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubCEAssessment> rdf:type owl:Class .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubEnrollAssessment
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#SubEnrollAssessment> rdf:type owl:Class ;
                                                                                              rdfs:comment "What differentiates these from SubCEAssessment is that these will inherit the data collection stage, whereas data collection stage does not apply to CE Assessments or their subcomponents." .


###  http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#User
<http://www.semanticweb.org/65225/ontologies/2026/1/hmis-test-ontology-6#User> rdf:type owl:Class .


[ <http://www.w3.org/ns/shacl#datatype> xsd:string ;
  <http://www.w3.org/ns/shacl#message> "EnrollmentCoC must be in format XX-NNN (e.g., CA-500)" ;
  <http://www.w3.org/ns/shacl#pattern> "^[A-Z]{2}-[0-9]{3}$" ;
  <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Info> ,
                                        <http://www.w3.org/ns/shacl#Warning> ;
  <http://www.w3.org/ns/shacl#sparql> [ <http://www.w3.org/ns/shacl#message> "EnrollmentCoC value {$value} is not a recognized CoC code." ;
                                        <http://www.w3.org/ns/shacl#select> """
                SELECT $this ?value WHERE {
                    $this hmis:EnrollmentCoC ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:CoCScheme ;
                                 skos:notation ?value .
                    }
                }
            """
                                      ]
] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:integer ;
   <http://www.w3.org/ns/shacl#maxCount> 1 ;
   <http://www.w3.org/ns/shacl#minCount> 1 ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation> ;
   <http://www.w3.org/ns/shacl#sparql> [ <http://www.w3.org/ns/shacl#message> "RelationshipToHoH value {$value} is invalid. Must be from RelationshipScheme (1-5)." ;
                                         <http://www.w3.org/ns/shacl#select> """
                SELECT $this ?value WHERE {
                    $this hmis:RelationshipToHoH ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:RelationshipScheme ;
                                 skos:notation ?value .
                    }
                }
            """
                                       ]
 ] .

[ <http://www.w3.org/ns/shacl#message> "ExitDate must be greater than or equal to EntryDate" ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this WHERE {
                $this hmis:EntryDate ?entry ;
                      hmis:ExitDate ?exit .
                FILTER(?exit < ?entry)
            }
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#message> "EntryDate cannot be in the future" ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this WHERE {
                $this hmis:EntryDate ?entry .
                FILTER(?entry > NOW())
            }
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:integer ;
   <http://www.w3.org/ns/shacl#maxCount> 1 ;
   <http://www.w3.org/ns/shacl#minCount> 0 ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation> ;
   <http://www.w3.org/ns/shacl#sparql> [ <http://www.w3.org/ns/shacl#message> "Gender value {$value} is invalid. Must be from GenderScheme (0-6, 8, 9, or 99)." ;
                                         <http://www.w3.org/ns/shacl#select> """
                SELECT $this ?value WHERE {
                    $this hmis:Gender ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:GenderScheme ;
                                 skos:notation ?value .
                    }
                }
            """
                                       ]
 ] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:string ;
   <http://www.w3.org/ns/shacl#message> "SSN must be in format XXX-XX-XXXX or XXXXXXXXX" ;
   <http://www.w3.org/ns/shacl#pattern> "^[0-9]{3}-[0-9]{2}-[0-9]{4}$|^[0-9]{9}$" ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Warning>
 ] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:integer ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation> ;
   <http://www.w3.org/ns/shacl#sparql> [ <http://www.w3.org/ns/shacl#message> "Destination value {$value} is invalid. Must be from DestinationScheme." ;
                                         <http://www.w3.org/ns/shacl#select> """
                SELECT $this ?value WHERE {
                    $this hmis:Destination ?value .
                    FILTER NOT EXISTS {
                        ?concept skos:inScheme hmis:DestinationScheme ;
                                 skos:notation ?value .
                    }
                }
            """
                                       ]
 ] .

[ <http://www.w3.org/ns/shacl#message> "Homelessness Prevention enrollments (ProjectType 12) must have DateOfEngagement." ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:inProject ?project .
                ?project hmis:ProjectType 12 .
                
                FILTER NOT EXISTS {
                    $this hmis:DateOfEngagement ?date .
                }
            }
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:string ;
   <http://www.w3.org/ns/shacl#maxCount> 1 ;
   <http://www.w3.org/ns/shacl#message> "UserID is required for all records" ;
   <http://www.w3.org/ns/shacl#minCount> 1 ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:integer ;
   <http://www.w3.org/ns/shacl#maxCount> 1 ;
   <http://www.w3.org/ns/shacl#minCount> 1 ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation> ;
   <http://www.w3.org/ns/shacl#sparql> [ <http://www.w3.org/ns/shacl#message> "SSNDataQuality value {$value} is invalid. Must be from SSNDataQualityScheme." ;
                                         <http://www.w3.org/ns/shacl#select> """
                SELECT $this ?value WHERE {
                    $this hmis:SSNDataQuality ?value .
                    FILTER NOT EXISTS {
                        ?concept a skos:Concept ;
                                 skos:inScheme hmis:SSNDataQualityScheme ;
                                 skos:notation ?value .
                    }
                }
            """
                                       ]
 ] .

[ <http://www.w3.org/ns/shacl#message> "Permanent Supportive Housing enrollments (ProjectType 3) require DisablingCondition = 1 (Yes)." ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:inProject ?project ;
                      hmis:DisablingCondition ?disability .
                ?project hmis:ProjectType 3 .
                
                FILTER(?disability != 1)
            }
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#message> "Street Outreach enrollments (ProjectType 4) must have DateOfEngagement." ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:inProject ?project .
                ?project hmis:ProjectType 4 .
                
                FILTER NOT EXISTS {
                    $this hmis:DateOfEngagement ?date .
                }
            }
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:integer ;
   <http://www.w3.org/ns/shacl#maxCount> 1 ;
   <http://www.w3.org/ns/shacl#minCount> 1 ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation> ;
