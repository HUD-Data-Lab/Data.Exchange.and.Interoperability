[ <http://www.w3.org/ns/shacl#message> "Household {$this} must have exactly one member with RelationshipToHoH = 1 (Self)." ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this (COUNT(?hoh) as ?hohCount) WHERE {
                $this a hmis:Household ;
                      hmis:hasMember ?enrollment .
                ?enrollment hmis:RelationshipToHoH 1 .
            }
            GROUP BY $this
            HAVING (?hohCount != 1)
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

