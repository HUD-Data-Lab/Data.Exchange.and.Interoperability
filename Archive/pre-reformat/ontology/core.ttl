   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation> ;
   <http://www.w3.org/ns/shacl#sparql> [ <http://www.w3.org/ns/shacl#message> "NativeHIPacific value {$value} is invalid. Must be from YesNoReasonsScheme." ;
                                         <http://www.w3.org/ns/shacl#select> """
                SELECT $this ?value WHERE {
                    $this hmis:NativeHIPacific ?value .
                    FILTER NOT EXISTS {
                        ?concept skos:inScheme hmis:YesNoReasonsScheme ;
                                 skos:notation ?value .
                    }
                }
            """
                                       ]
 ] .

[ <http://www.w3.org/ns/shacl#message> "DOB cannot be in the future" ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this WHERE {
                $this hmis:DOB ?dob .
                FILTER(?dob > NOW())
            }
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:string ;
   <http://www.w3.org/ns/shacl#maxCount> 1 ;
   <http://www.w3.org/ns/shacl#message> "LastName is required" ;
   <http://www.w3.org/ns/shacl#minCount> 1 ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#message> "Enrollment has been open for over 1 year without exit. Verify enrollment is still active." ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:EntryDate ?entry .
                FILTER NOT EXISTS { $this hmis:ExitDate ?exit }
                FILTER(?entry < NOW() - \"P365D\"^^xsd:duration)
            }
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Info>
 ] .

[ <http://www.w3.org/ns/shacl#message> "Services Only enrollments (ProjectType 6) must have DateOfEngagement." ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this WHERE {
                $this a hmis:Enrollment ;
                      hmis:inProject ?project .
                ?project hmis:ProjectType 6 .
                
                FILTER NOT EXISTS {
                    $this hmis:DateOfEngagement ?date .
                }
            }
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:integer ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation> ;
   <http://www.w3.org/ns/shacl#sparql> [ <http://www.w3.org/ns/shacl#message> "Asian value {$value} is invalid. Must be from YesNoReasonsScheme." ;
                                         <http://www.w3.org/ns/shacl#select> """
                SELECT $this ?value WHERE {
                    $this hmis:Asian ?value .
                    FILTER NOT EXISTS {
                        ?concept skos:inScheme hmis:YesNoReasonsScheme ;
                                 skos:notation ?value .
                    }
                }
            """
                                       ]
 ] .

[ <http://www.w3.org/ns/shacl#datatype> xsd:string ;
   <http://www.w3.org/ns/shacl#maxCount> 1 ;
   <http://www.w3.org/ns/shacl#maxLength> 32 ;
   <http://www.w3.org/ns/shacl#message> "PersonalID is required and must be 1-32 characters" ;
   <http://www.w3.org/ns/shacl#minCount> 1 ;
   <http://www.w3.org/ns/shacl#minLength> 1 ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

[ <http://www.w3.org/ns/shacl#message> "DateUpdated must be greater than or equal to DateCreated" ;
   <http://www.w3.org/ns/shacl#select> """
            SELECT $this WHERE {
                $this hmis:DateCreated ?created ;
                      hmis:DateUpdated ?updated .
                FILTER(?updated < ?created)
            }
        """ ;
   <http://www.w3.org/ns/shacl#severity> <http://www.w3.org/ns/shacl#Violation>
 ] .

